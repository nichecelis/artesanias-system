# =============================================================
# Artesanías Backend — Variables de entorno
# Copiar a .env y completar con valores reales
# =============================================================

# App
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Base de datos PostgreSQL
DATABASE_URL="postgresql://artesanias_user:artesanias_pass@localhost:5432/artesanias_db?schema=public"

# JWT
JWT_SECRET=pon_aqui_cualquier_texto_largo_de_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=otro_texto_diferente_tambien_largo
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=artesanias:

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS — separar múltiples origins con coma
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Bcrypt
BCRYPT_ROUNDS=12

# Logs
LOG_LEVEL=debug
