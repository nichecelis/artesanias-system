// =============================================================
// Artesanías SaaS — Schema de Prisma
// Base de datos: PostgreSQL
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// ENUMS
// =============================================================

enum Rol {
  ADMINISTRADOR
  PRODUCCION
  VENTAS
  CONTABILIDAD
}

enum EstadoProducto {
  ACTIVO
  INACTIVO
}

enum EstadoPedido {
  PENDIENTE
  EN_CORTE
  EN_DECORACION
  LISTO
  DESPACHADO
  CANCELADO
}

enum TipoCuenta {
  AHORROS
  CORRIENTE
}

enum TipoGrupo {
  GRUPO
  ELITE
}

// =============================================================
// MÓDULO 5b — GRUPOS DE DECORADORAS
// =============================================================

model Grupo {
  id                    String    @id @default(uuid())
  nombre                String
  tipo                  TipoGrupo @default(GRUPO)
  direccion             String?
  telefono              String?
  responsable           String?
  porcentajeResponsable Float     @default(0)
  activo                Boolean   @default(true)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  decoradoras Decoradora[]

  @@index([tipo])
  @@map("grupos")
}

// =============================================================
// MÓDULO 1 — USUARIOS
// =============================================================

model Usuario {
  id           String   @id @default(uuid())
  nombre       String
  correo       String   @unique
  passwordHash String   @map("password_hash")
  rol          Rol      @default(VENTAS)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Auditoría
  auditLogs AuditLog[]

  @@index([correo])
  @@index([rol])
  @@map("usuarios")
}

// =============================================================
// MÓDULO 2 — PRODUCTOS
// =============================================================

model Producto {
  id               String         @id @default(uuid())
  nombre           String
  descripcion      String?
  precioVenta      Decimal        @map("precio_venta") @db.Decimal(12, 2)
  precioDecoracion Decimal        @map("precio_decoracion") @db.Decimal(12, 2)
  estado           EstadoProducto @default(ACTIVO)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  pedidoProductos PedidoProducto[]
  productoCliente ProductoCliente[]
  decoraciones    Decoracion[]

  @@index([estado])
  @@index([nombre])
  @@map("productos")
}

// =============================================================
// MÓDULO 2b — PRECIOS POR CLIENTE
// =============================================================

model ProductoCliente {
  id          String   @id @default(uuid())
  productoId  String   @map("producto_id")
  producto    Producto @relation(fields: [productoId], references: [id])
  clienteId   String   @map("cliente_id")
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  precioVenta Decimal  @map("precio_venta") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([productoId, clienteId])
  @@index([productoId])
  @@index([clienteId])
  @@map("producto_clientes")
}

// =============================================================
// MÓDULO 3 — CLIENTES
// =============================================================

model Cliente {
  id             String   @id @default(uuid())
  nombre         String
  documento      String   @unique
  direccion      String?
  telefono       String?
  transportadora String?
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  pedidos         Pedido[]
  productoCliente ProductoCliente[]

  @@index([documento])
  @@index([nombre])
  @@map("clientes")
}

// =============================================================
// MÓDULO 4 — PEDIDOS / VENTAS
// =============================================================

model Pedido {
  id        String  @id @default(uuid())
  codigo    String  @unique
  clienteId String  @map("cliente_id")
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  laser String?

  estado        EstadoPedido @default(PENDIENTE)
  observaciones String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productos    PedidoProducto[]
  decoraciones Decoracion[]

  @@map("pedidos")
}

// =============================================================
// MÓDULO 5 — DECORADORAS
// =============================================================

model Decoradora {
  id         String      @id @default(uuid())
  nombre     String
  documento  String      @unique
  telefono   String?
  banco      String?
  numCuenta  String?     @map("num_cuenta")
  tipoCuenta TipoCuenta? @map("tipo_cuenta")
  grupoId    String?     @map("grupo_id")
  grupo      Grupo?      @relation(fields: [grupoId], references: [id])
  activa     Boolean     @default(true)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  decoraciones Decoracion[]
  prestamos    Prestamo[]

  @@index([documento])
  @@map("decoradoras")
}

// =============================================================
// MÓDULO 4b — PRODUCTOS POR PEDIDO
// =============================================================

model PedidoProducto {
  id       String @id @default(uuid())
  pedidoId String @map("pedido_id")
  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  productoId String   @map("producto_id")
  producto   Producto @relation(fields: [productoId], references: [id])

  cantidadPedido  Int  @map("cantidad_pedido")
  cantidadPlancha Int? @map("cantidad_plancha")

  estado EstadoPedido @default(PENDIENTE)

  // 🔥 CORTE
  fechaInicioCorte DateTime? @map("fecha_inicio_corte") @db.Date
  fechaConteo      DateTime? @map("fecha_conteo") @db.Date
  cantidadTareas   Int?
  corte1           Int?
  corte2           Int?
  corte3           Int?

  // 🔥 DECORACIÓN
  fechaAsignacion  DateTime? @map("fecha_asignacion") @db.Date
  cantidadRecibida Int?

  // 🔥 DESPACHO
  fechaDespacho    DateTime? @map("fecha_despacho") @db.Date
  cantidadDespacho Int?
  cantidadFaltante Int?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([pedidoId])
  @@index([productoId])
  @@index([estado])
  @@map("pedido_productos")
}

// =============================================================
// MÓDULO 6 — CONTROL DE DECORACIÓN
// Registra egreso de productos a decoradoras e ingreso de vuelta
// =============================================================

model Decoracion {
  id           String     @id @default(uuid())
  pedidoId     String     @map("pedido_id")
  pedido       Pedido     @relation(fields: [pedidoId], references: [id])
  decoradoraId String     @map("decoradora_id")
  decoradora   Decoradora @relation(fields: [decoradoraId], references: [id])
  productoId   String     @map("producto_id")
  producto     Producto   @relation(fields: [productoId], references: [id])

  // Egreso
  fechaEgreso    DateTime @map("fecha_egreso") @db.Date
  cantidadEgreso Int      @map("cantidad_egreso")

  // Ingreso
  fechaIngreso    DateTime? @map("fecha_ingreso") @db.Date
  cantidadIngreso Int?      @map("cantidad_ingreso")
  arreglos        Int       @default(0)
  perdidas        Int       @default(0)

  // Financiero
  precioDecoracion Decimal   @map("precio_decoracion") @db.Decimal(12, 2)
  total            Decimal   @default(0) @db.Decimal(12, 2)
  compras          Decimal   @default(0) @db.Decimal(12, 2)
  abonosPrestamo   Decimal   @default(0) @map("abonos_prestamo") @db.Decimal(12, 2)
  prestamoId       String?   @map("prestamo_id")
  prestamo         Prestamo? @relation(fields: [prestamoId], references: [id])
  subtotal         Decimal   @default(0) @db.Decimal(12, 2)
  totalPagar       Decimal   @default(0) @map("total_pagar") @db.Decimal(12, 2)
  pagado           Boolean   @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([pedidoId])
  @@index([decoradoraId])
  @@index([productoId])
  @@index([fechaEgreso])
  @@index([pagado])
  @@map("decoraciones")
}

// =============================================================
// MÓDULO 7 — PRÉSTAMOS A DECORADORAS
// =============================================================

model Prestamo {
  id           String      @id @default(uuid())
  decoradoraId String?     @map("decoradora_id")
  decoradora   Decoradora? @relation(fields: [decoradoraId], references: [id])
  empleadoId   String?     @map("empleado_id")
  empleado     Empleado?   @relation(fields: [empleadoId], references: [id])
  monto        Decimal     @db.Decimal(12, 2)
  fecha        DateTime    @db.Date
  saldo        Decimal     @db.Decimal(12, 2)
  cuotas       Int?
  observacion  String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  abonos       Abono[]
  decoraciones Decoracion[]
  nominas      Nomina[]

  @@index([decoradoraId])
  @@index([empleadoId])
  @@index([fecha])
  @@map("prestamos")
}

model Abono {
  id         String   @id @default(uuid())
  prestamoId String   @map("prestamo_id")
  prestamo   Prestamo @relation(fields: [prestamoId], references: [id])
  monto      Decimal  @db.Decimal(12, 2)
  fecha      DateTime @db.Date
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([prestamoId])
  @@map("abonos")
}

// =============================================================
// MÓDULO 8 — EMPLEADOS
// =============================================================

model Empleado {
  id        String   @id @default(uuid())
  nombre    String
  documento String   @unique
  salario   Decimal  @db.Decimal(12, 2)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  nominas   Nomina[]
  prestamos Prestamo[]

  @@index([documento])
  @@map("empleados")
}

// =============================================================
// MÓDULO 9 — NÓMINA
// =============================================================

model Nomina {
  id         String    @id @default(uuid())
  empleadoId String    @map("empleado_id")
  empleado   Empleado  @relation(fields: [empleadoId], references: [id])
  prestamoId String?   @map("prestamo_id")
  prestamo   Prestamo? @relation(fields: [prestamoId], references: [id])

  fecha          DateTime @db.Date
  diasTrabajados Int      @map("dias_trabajados")
  salarioDia     Decimal  @default(0) @map("salario_dia") @db.Decimal(12, 2)
  subtotalDias   Decimal  @default(0) @map("subtotal_dias") @db.Decimal(12, 2)
  horasExtras    Decimal  @default(0) @map("horas_extras") @db.Decimal(8, 2)
  valorHoraExtra Decimal  @default(0) @map("valor_hora_extra") @db.Decimal(12, 2)
  subtotalHoras  Decimal  @default(0) @map("subtotal_horas") @db.Decimal(12, 2)
  abonosPrestamo Decimal  @default(0) @map("abonos_prestamo") @db.Decimal(12, 2)
  totalPagar     Decimal  @map("total_pagar") @db.Decimal(12, 2)
  observaciones  String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([empleadoId])
  @@index([prestamoId])
  @@index([fecha])
  @@map("nomina")
}

// =============================================================
// AUDITORÍA — Trazabilidad de cambios
// =============================================================

model AuditLog {
  id           String   @id @default(uuid())
  usuarioId    String?  @map("usuario_id")
  usuario      Usuario? @relation(fields: [usuarioId], references: [id])
  accion       String // CREATE | UPDATE | DELETE
  entidad      String // nombre de la tabla afectada
  entidadId    String   @map("entidad_id")
  datosAntes   Json?    @map("datos_antes")
  datosDespues Json?    @map("datos_despues")
  ip           String?
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([usuarioId])
  @@index([entidad])
  @@index([createdAt])
  @@map("audit_logs")
}
