# =============================================================
# Artesanias Backend - Produccion
# =============================================================

NODE_ENV=production
PORT=3001
API_PREFIX=/api/v1

DATABASE_URL=postgresql://artesanias_user:artesanias_pass@postgres:5432/artesanias_db?schema=public

JWT_SECRET=cambia-este-secret-por-uno-muy-largo-y-seguro-123456789012345
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=otro-secret-diferente-tambien-muy-largo-y-seguro-abcdef
JWT_REFRESH_EXPIRES_IN=7d

REDIS_URL=redis://redis:6379
REDIS_PREFIX=artesanias:

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

CORS_ORIGINS=http://localhost,http://localhost:80

BCRYPT_ROUNDS=12

LOG_LEVEL=info
