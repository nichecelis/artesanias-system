# =============================================================
# Artesanías Backend — Variables de entorno
# Copiar a .env y completar con valores reales
# =============================================================

# App
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Base de datos PostgreSQL
DATABASE_URL="postgresql://artesanias_user:artesanias_pass@localhost:5432/artesanias_db?schema=public"

# JWT
JWT_SECRET="tu-secret-muy-largo-y-seguro-aqui-minimo-32-caracteres"
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET="tu-refresh-secret-muy-largo-y-seguro-aqui-minimo-32-caracteres"
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=artesanias:

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# CORS — separar múltiples origins con coma
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Bcrypt
BCRYPT_ROUNDS=12

# Logs
LOG_LEVEL=debug
